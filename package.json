{
  "name": "steam-tierlist",
  "productName": "Steam Tierlist",
  "version": "1.0.0",
  "description": "Build a tier list of your Steam library with game icons.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -m -w -l --publish never",
    "build:mac": "electron-builder -m --publish never",
    "build:win": "electron-builder -w --publish never",
    "build:linux": "electron-builder -l --publish never",
    "release:mac": "electron-builder -m --publish always",
    "release:win": "electron-builder -w --publish always",
    "release:linux": "electron-builder -l --publish always"
  },
  "author": "Enzo",
  "license": "BSD-2-Clause",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "build": {
    "appId": "ch.officeworks.steamtierlist",
    "productName": "Steam Tierlist",
    "publish": {
      "provider": "github",
      "owner": "qcom-toolbox",
      "repo": "HM"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "style.css",
      "LICENSE",
      "THIRD-PARTY-LICENSES.md",
      "node_modules/html2canvas/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Game"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.games"
    }
  }
}
